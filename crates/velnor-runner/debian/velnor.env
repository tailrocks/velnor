# Velnor runner configuration.
# Edit, then:  sudo systemctl restart velnor-daemon
#
# After editing, the runner registers JIT GitHub runners against VELNOR_URL using
# GITHUB_TOKEN and starts polling for jobs.

# GitHub token for runner registration lives in /etc/velnor/secrets.env
# (0600, operator-owned, never shipped or modified by the package):
#   GITHUB_TOKEN=ghp_...
# Leaving it here also works (secrets.env wins if both are set), but the
# separate file survives package upgrades and config tooling.
GITHUB_TOKEN=

# Repository, org, or enterprise URL to register runners against.
VELNOR_URL=https://github.com/OWNER/REPO

# Base runner display name (each slot appends -slot-N).
VELNOR_NAME=velnor

# Comma-separated runner labels. Jobs target these via runs-on.
VELNOR_LABELS=velnor,velnor-target-mvp

# Number of concurrent job slots.
VELNOR_SLOTS=4

# Trust scope for opt-in persistent target buckets. Use one value per
# daemon/pool trust boundary (for example: trusted, public-forks).
VELNOR_TRUST_SCOPE=trusted

# Default Docker resource cap per job container. Operators can tune these per
# daemon instance; empty values disable the matching cap.
VELNOR_JOB_CPUS=4
VELNOR_JOB_MEMORY=12g

# Host work directory for job state.
VELNOR_WORK_DIR=/var/lib/velnor/work
