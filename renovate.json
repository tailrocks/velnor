{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 20,
  "commitBody": "Signed-off-by: Renovate Bot <renovate@whitesourcesoftware.com>",
  "recreateWhen": "always",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "at any time"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "mise tool pins in the job image Dockerfile (mise use --global ...)",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "'cargo:cargo-nextest@(?<currentValue>[0-9.]+)'"
      ],
      "datasourceTemplate": "crate",
      "depNameTemplate": "cargo-nextest"
    },
    {
      "customType": "regex",
      "description": "rust-script pin in the job image Dockerfile",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "'cargo:rust-script@(?<currentValue>[0-9.]+)'"
      ],
      "datasourceTemplate": "crate",
      "depNameTemplate": "rust-script"
    },
    {
      "customType": "regex",
      "description": "just pin in the job image Dockerfile",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "\\bjust@(?<currentValue>[0-9.]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "casey/just"
    },
    {
      "customType": "regex",
      "description": "protoc pin in the job image Dockerfile",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "\\bprotoc@(?<currentValue>[0-9.]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "protocolbuffers/protobuf",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "gh CLI pin in the job image Dockerfile",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "\\bgh@(?<currentValue>[0-9.]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "cli/cli",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "sccache pin in the job image Dockerfile",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "ver=\"v(?<currentValue>[0-9.]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mozilla/sccache",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "mise installer pin in the job image Dockerfile",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "MISE_VERSION=\"v(?<currentValue>[0-9.]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "jdx/mise",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "rust toolchain pin in the job image Dockerfile (kept in sync with rust-toolchain.toml by Renovate)",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "\\brust@(?<currentValue>[0-9.]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "rust-lang/rust"
    },
    {
      "customType": "regex",
      "description": "hadolint pin in the job image Dockerfile",
      "managerFilePatterns": [
        "/^docker\\/job-ubuntu\\.Dockerfile$/"
      ],
      "matchStrings": [
        "hadolint_ver=\"v(?<currentValue>[0-9.]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "hadolint/hadolint",
      "extractVersionTemplate": "^v(?<version>.*)$"
    }
  ]
}
